{
  "name": "dev-trunk-plugins-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Configuration and setup tools for trunk plugins.",
  "license": "WTFPL-v3.1",
  "author": "Ai Vonie",
  "type": "module",
  "scripts": {
    "npm:start": "npm install",
    "npm-audit:fix": "npm audit fix --force",
    "trunk:check": "trunk check --all --fix",
    "trunk:format": "trunk fmt --all",
    "trunk:init": "npm exec trunk init",
    "tscanner:check": "npx tscanner check",
    "tscanner:init": "npx tscanner init --full",
    "update-deps": "npm update --save",
    "update-deps-check": "npm outdated",
    "upgrade-deps": "npx npm-check-updates -u && npm install"
  },
  "overrides": {
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@trunkio/launcher": "^1.3.4"
  }
}
